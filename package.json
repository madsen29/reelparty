{
  "name": "reelparty",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"npm run dev:server\" \"npm run dev:web\"",
    "dev:tunnel": "TUNNEL=1 concurrently -n api,web,tunnel -c blue,green,magenta \"npm run dev:server\" \"npm run dev:web\" \"ngrok http 127.0.0.1:5173\"",
    "dev:web": "vite",
    "dev:server": "lsof -ti:3001 | xargs kill -9 2>/dev/null; node --watch server/index.js",
    "tunnel": "ngrok http 127.0.0.1:5173",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "express": "^4.21.2",
    "lucide-react": "^0.383.0",
    "mongodb": "^6.12.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.1.2",
    "vite": "^5.3.0"
  }
}
